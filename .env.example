# Copy to .env.local (dev) and set in your host's env (production/preview).

# Canonical public origin — drives metadataBase, canonicals, sitemap.xml,
# robots.txt and JSON-LD. No trailing slash. Falls back to https://footdoot.com.
NEXT_PUBLIC_SITE_URL=https://footdoot.com

# Google Search Console verification token (Settings → Ownership → HTML tag).
# Optional — when set, renders <meta name="google-site-verification"> on every page.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
